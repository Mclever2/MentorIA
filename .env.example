
# ══════════════════════════════════════════════════════════════════════════════
# CLAVE API OPENAI — GPT-4o mini (pago por uso)
# ══════════════════════════════════════════════════════════════════════════════
#
# Una sola clave para todos los agentes — OpenAI no requiere rotación.
# Obtén tu clave en: https://platform.openai.com/api-keys
# Con $5 de crédito (Tier 1): 500 RPM y 200,000 TPM para gpt-4o-mini.
#
# ──────────────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-...


# ── Storage — dejar vacío para usar almacenamiento local ─────────────────────
# Si GCS_BUCKET_NAME está definido, los JSONs de run se suben automáticamente
GCS_BUCKET_NAME=

# Fuente de rúbricas: local | gcs | gdrive
CONTEXT_SOURCE=local

# Google Drive — JSON mapeando key → file_id de Drive
# Ejemplo: {"upao_ingenieria_de_sistemas_tesis": "1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms"}
GDRIVE_RUBRIC_MAP={}


# ── Tavily — búsqueda web de reglamentos por universidad (opcional) ───────────
# Plan gratuito: https://tavily.com  (Dashboard → API Keys).
# Si se deja vacío, "Buscar universidad" no funciona y se usa el fallback de
# subir el reglamento manualmente.
TAVILY_API_KEY=


# ── Parámetros del flujo ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_ITERATIONS=3
MAX_DEBATE_ROUNDS=2


# ── Supabase (auth + historial de asesorías) ──────────────────────────────────
# JWT Secret del proyecto: Supabase Dashboard → Project Settings → API → JWT Secret
# Si se deja vacío, la API corre SIN autenticación (solo para desarrollo local).
SUPABASE_JWT_SECRET=

# Orígenes permitidos para CORS (URL del frontend en Cloud Run), separados por coma
# Ejemplo: https://mentoria-web-xxxxx-uc.a.run.app,http://localhost:5173
ALLOWED_ORIGINS=*

# Precalentar embeddings + grafo + biblioteca al arrancar (1 = sí, recomendado en Cloud Run)
PRELOAD_ON_STARTUP=1


# ── LangSmith (opcional — para tracing y debugging) ───────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls_...
# LANGCHAIN_PROJECT=mentoria-multiagente
